# =============================================================================
# FlirtCraft - Environment Variables Configuration (Development)
# =============================================================================
# Copy this file to .env and fill in your actual values
# This file contains all environment variables needed for local development
# =============================================================================

# =============================================================================
# Application Configuration
# =============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=debug
SECRET_KEY=your-super-secret-key-change-this-in-production-at-least-32-characters

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
# Local PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL=postgresql://flirtcraft_user:flirtcraft_pass@localhost:5432/flirtcraft_db

# Alternative database URLs for different environments:
# DATABASE_URL=postgresql://username:password@localhost:5432/flirtcraft_db
# DATABASE_URL=postgresql://username:password@your-database-host:5432/database_name

# =============================================================================
# Redis Configuration (Caching & Background Jobs)
# =============================================================================
# Local Redis connection (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379/0

# Redis with password (if configured):
# REDIS_URL=redis://:password@localhost:6379/0

# Redis Cloud or external Redis:
# REDIS_URL=redis://username:password@your-redis-host:6379/0

# =============================================================================
# Google Gemini AI Configuration
# =============================================================================
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Or from Google AI Studio: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Configuration (optional)
GEMINI_MODEL_PRIMARY=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.0-flash
GEMINI_REQUESTS_PER_MINUTE=60
GEMINI_REQUESTS_PER_DAY=1500

# =============================================================================
# Supabase Configuration
# =============================================================================
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anonymous-key-here
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# For local Supabase development (if using Supabase CLI):
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=your-local-anon-key
# SUPABASE_SERVICE_KEY=your-local-service-key

# =============================================================================
# CORS Configuration (Frontend Development)
# =============================================================================
# Add your frontend URLs here (React Native dev server, Expo, etc.)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,exp://192.168.1.100:19000

# For production, use your actual domain:
# ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com

# =============================================================================
# Authentication & Security
# =============================================================================
# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-different-from-main-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_HASH_ROUNDS=12

# =============================================================================
# API Configuration
# =============================================================================
API_V1_PREFIX=/api/v1
API_DOCS_URL=/docs
API_REDOC_URL=/redoc
API_OPENAPI_URL=/openapi.json

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# =============================================================================
# Background Jobs & Queue Configuration
# =============================================================================
# RQ (Redis Queue) settings
RQ_DEFAULT_QUEUE=default
RQ_HIGH_PRIORITY_QUEUE=high
RQ_LOW_PRIORITY_QUEUE=low
RQ_WORKER_COUNT=2

# Job timeouts (in seconds)
RQ_DEFAULT_JOB_TIMEOUT=180
RQ_HIGH_PRIORITY_TIMEOUT=300
RQ_LOW_PRIORITY_TIMEOUT=600

# =============================================================================
# File Upload & Storage
# =============================================================================
# Maximum file sizes (in bytes)
MAX_UPLOAD_SIZE=10485760  # 10MB
MAX_IMAGE_SIZE=5242880    # 5MB

# Upload directories
UPLOAD_DIRECTORY=./uploads
TEMP_DIRECTORY=./tmp

# =============================================================================
# Monitoring & Logging
# =============================================================================
# Sentry (Error Tracking) - Get DSN from: https://sentry.io/
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Log file configuration
LOG_FILE_PATH=./logs/flirtcraft.log
LOG_FILE_MAX_SIZE=10485760  # 10MB
LOG_FILE_BACKUP_COUNT=5

# =============================================================================
# Development & Testing Configuration
# =============================================================================
# Testing database (separate from development)
TEST_DATABASE_URL=postgresql://flirtcraft_user:flirtcraft_pass@localhost:5432/flirtcraft_test_db

# Development user credentials (for testing)
DEV_USER_EMAIL=dev@flirtcraft.local
DEV_USER_PASSWORD=dev123password

# Feature flags for development
FEATURE_AI_DEBUGGING=true
FEATURE_DETAILED_LOGGING=true
FEATURE_MOCK_PAYMENTS=true
FEATURE_DEV_ENDPOINTS=true

# =============================================================================
# Performance & Optimization
# =============================================================================
# Cache TTL settings (in seconds)
CACHE_TTL_USER_PROFILE=3600      # 1 hour
CACHE_TTL_SCENARIOS=86400        # 24 hours
CACHE_TTL_CONVERSATIONS=1800     # 30 minutes
CACHE_TTL_AI_RESPONSES=7200      # 2 hours

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# Mobile App Integration
# =============================================================================
# Deep linking configuration
APP_SCHEME=flirtcraft
UNIVERSAL_LINK_DOMAIN=flirtcraft.app

# Push notification configuration (if implementing)
PUSH_NOTIFICATION_KEY=your-push-notification-key
PUSH_NOTIFICATION_TEAM_ID=your-team-id
PUSH_NOTIFICATION_BUNDLE_ID=com.flirtcraft.app

# =============================================================================
# Third-party Integrations
# =============================================================================
# RevenueCat (Subscription Management) - Get from: https://app.revenuecat.com/
REVENUECAT_PUBLIC_KEY=your-revenuecat-public-key
REVENUECAT_SECRET_KEY=your-revenuecat-secret-key
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret

# Analytics (optional)
ANALYTICS_API_KEY=your-analytics-api-key
ANALYTICS_PROJECT_ID=your-analytics-project-id

# =============================================================================
# Docker & Development Server Configuration
# =============================================================================
# Port configuration for development
BACKEND_PORT=8000
FRONTEND_PORT=3000
EXPO_PORT=19000

# Docker development settings
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# Hot reloading settings
CHOKIDAR_USEPOLLING=true  # For Windows/Docker file watching
WATCHPACK_POLLING=true    # Alternative file watching

# =============================================================================
# Local Development URLs
# =============================================================================
# These URLs are automatically set by docker-compose but can be overridden
LOCAL_BACKEND_URL=http://localhost:8000
LOCAL_DB_ADMIN_URL=http://localhost:8080  # Adminer
LOCAL_REDIS_ADMIN_URL=http://localhost:8081  # Redis Commander

# =============================================================================
# Configuration Validation
# =============================================================================
# Set to true to validate all environment variables on startup
VALIDATE_ENV_ON_STARTUP=true

# Required environment variables (will be checked if validation is enabled)
REQUIRED_ENV_VARS=GEMINI_API_KEY,DATABASE_URL,REDIS_URL,SECRET_KEY

# =============================================================================
# Usage Instructions:
# =============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual API keys and configuration values
# 3. The .env file is automatically loaded by docker-compose
# 4. Never commit your .env file to version control
# 5. Update this .env.example file when adding new environment variables
# 
# Required for basic functionality:
# - GEMINI_API_KEY: Get from Google AI Console
# - SUPABASE_URL and keys: Get from Supabase dashboard
# - SECRET_KEY: Generate a secure random string
# 
# Optional but recommended:
# - SENTRY_DSN: For error tracking
# - REVENUECAT keys: For subscription management
# 
# Quick setup for local development:
# 1. Get Gemini API key from https://ai.google.dev/
# 2. Create Supabase project at https://supabase.com/
# 3. Generate secure SECRET_KEY (you can use: openssl rand -base64 32)
# 4. Run: docker-compose up --build
# =============================================================================